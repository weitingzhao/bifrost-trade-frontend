# Production build — same-origin API paths via infra nginx (Phase 2C).
# Copy to .env.production before `docker compose build frontend` or `npm run build`.
VITE_API_MONITOR=/api/monitor
VITE_API_MASSIVE=/api/massive
VITE_API_DOCS=/api/docs
VITE_API_OPS=/api/ops
VITE_API_TRADING=/api/trading
VITE_API_STRATEGY=/api/strategy
VITE_API_PORTFOLIO=/api/portfolio
VITE_API_MARKET=/api/market
VITE_API_RESEARCH=/api/research
# Bifrost Ops Console (LAN or localhost — optional peer link in sidebar)
VITE_OPS_CONSOLE_URL=http://127.0.0.1:5180
