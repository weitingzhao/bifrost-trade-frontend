{
  "name": "bifrost-trade-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write src",
    "test": "vitest",
    "test:run": "vitest run",
    "check:legacy-css": "bash scripts/check-legacy-css.sh",
    "sync:docker-lock": "docker run --rm --platform linux/amd64 -v \"$(pwd)\":/app -w /app node:20-slim npm install",
    "sync:massive-stocks-coverage": "cp ../bifrost-trader-engine/docs/plans/massive_stocks_api_coverage.html public/plans/massive_stocks_api_coverage.html",
    "sync:massive-api-coverage": "cp ../bifrost-trader-engine/frontend/public/plans/massive_api_coverage.html public/plans/massive_api_coverage.html",
    "prepare": "husky"
  },
  "dependencies": {
    "@bifrost/ui": "file:../bifrost-ui",
    "@fontsource-variable/geist": "^5.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.100.14",
    "@tanstack/react-query-devtools": "^5.100.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.15.1",
    "shadcn": "^4.8.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "typescript": "~5.6.2",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.4.10",
    "vitest": "^4.1.7"
  }
}
